# APRIL local environment example. Copy to ${APRIL_HOME}/.env and edit.
#
# Effective settings precedence (highest first):
#   1. process environment   2. ${APRIL_HOME}/.env   3. configs/april.yaml   4. defaults
# `run april setup tokens` writes the two tokens below to ${APRIL_HOME}/.env at
# mode 0600. Never commit a real .env.

APRIL_HOME=/Users/you/path/to/april

# Local-only loopback bearer tokens. Do NOT keep an active placeholder here:
# run `run april setup tokens`, which writes strong generated values into
# ${APRIL_HOME}/.env at mode 0600 (and prints nothing secret). Production mode
# (APRIL_ENV=production) rejects the known development defaults, the commented
# placeholders below, and empty/missing tokens at startup. The lines below stay
# commented so a fresh copy is insecure-by-omission, not insecure-by-placeholder.
# APRIL_API_TOKEN=change-me-local-token
# APRIL_RUNTIME_TOKEN=change-me-runtime-token

APRIL_API_HOST=127.0.0.1
APRIL_API_PORT=8765
APRIL_RUNTIME_HOST=127.0.0.1
APRIL_RUNTIME_PORT=8766
APRIL_RUNTIME_URL=http://127.0.0.1:8766

# Runtime backend. The DEFAULT is `llama_cpp` (matching configs/models.yaml),
# which runs real local GGUF models and needs the optional `.[runtime]` extra
# plus model files you provide. Uncomment the line below ONLY for development and
# the deterministic test/verification flows, which require no model files:
# APRIL_RUNTIME_BACKEND=fake
APRIL_RUNTIME_MAX_LOADED_SPECIALIST_MODELS=2

APRIL_DATABASE_PATH=data/april.db
APRIL_ALLOWED_FILESYSTEM_ROOTS=/Users/you/path/to/projects,/Users/you/path/to/april
APRIL_EXTERNAL_ACTIONS_ENABLED=false

# Voice is OFF by default and entirely local. Enabling it needs the optional
# `.[voice]` extra plus whisper.cpp / Piper binaries and models you provide.
# These paths stay unset until you configure them.
APRIL_VOICE_ENABLED=false
APRIL_VOICE_INPUT_DEVICE=
APRIL_VOICE_OUTPUT_DEVICE=
APRIL_VOICE_MAX_RECORD_SECONDS=30
APRIL_WHISPER_BINARY_PATH=
APRIL_WHISPER_MODEL_PATH=
APRIL_PIPER_BINARY_PATH=
APRIL_PIPER_MODEL_PATH=
APRIL_WAKE_WORD_MODEL_PATH=

# Register repositories as APRIL projects before repository tools can use them:
#   run april agent run coding_agent "Inspect this repository" --project-id PROJECT_ID
# Deterministic local verification (fake backend, temp data, dynamic ports):
#   run april verify --fake
# Optional real-model test. Leave unset unless you already have a GGUF file:
# APRIL_TEST_GGUF_PATH=/absolute/path/to/model.gguf
